{
	"schemaVersion": 1,
	"id": "phonk-edit-mod",
	"version": "${version}",
	"name": "Phonk Edit Mod",
	"description": "Recreates the viral YouTube Shorts 'Phonk Edit' meme in Minecraft! Features random pauses with phonk music, grayscale filter, skull overlays, beat-synced zoom & blur effects, camera shake, and mobile format bars. Fully configurable!",
	"authors": [
		"luigi"
	],
	"contact": {
		"homepage": "https://github.com/LuigiLoeck/Phonk-Edit-Mod",
		"sources": "https://github.com/LuigiLoeck/Phonk-Edit-Mod",
		"issues": "https://github.com/LuigiLoeck/Phonk-Edit-Mod/issues"
	},
	"license": "MIT",
	"icon": "assets/phonk-edit-mod/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.luigi.phonkeditmod.PhonkEditMod"
		],
		"client": [
			"com.luigi.phonkeditmod.PhonkEditModClient"
		]
	},
	"mixins": [
		"phonk-edit-mod.mixins.json",
		{
			"config": "phonk-edit-mod.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.17.3",
		"minecraft": "~1.21",
		"java": ">=21",
		"fabric-api": "*"
	},
	"suggests": {
		"another-mod": "*"
	}
}